<div>
  <h3>Book detail</h3>
  #ユーザー画像
  <p><%= image_tag 'no_image.jpg' %></p>
  <p><%= @book.user.name %></p>

  <p>ショップ名：<%= @book.title %></p>
  <p><%= @book.body %></p>
  <% if @book.user == Current.user %>
    <%= link_to "Destroy", book_path(@book), data: { turbo_method: :delete } %>
  <% end %>

</div>