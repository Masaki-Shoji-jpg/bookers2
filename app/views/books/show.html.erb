<div>
  <h3>Book detail</h3>
  <%#ユーザー画像 %>
  <p><%= image_tag @post_image.user.get_profile_image(100,100) %></p>
  <p><%= @book.user.name %></p>


  <p><%= @book.title %></p>
  <p><%= @book.body %></p>
  <% if @book.user == Current.user %>
    <%= link_to "Destroy", book_path(@book), data: { turbo_method: :delete } %>
  <% end %>

</div>