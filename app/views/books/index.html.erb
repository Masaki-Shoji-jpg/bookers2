<h3>Books</h3>
<% @books.each do |book| %>
  <div>
    <%= link_to book_path(book.id) do %>
     <p><%= image_tag post_image.user.get_profile_image(100,100) %></p>
    <% end %>
    <%= link_to book_path(book.id) do %>
    <p>Title：<%= book.title %></p>
    <% end %>
    <p>Opinion：<%= book.body %></p>
  </div>
<% end %>